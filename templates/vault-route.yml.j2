apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: vault
  namespace: "{{ vault_namespace }}"
spec:
  host: "{{ vault_route_host }}"
  to:
    kind: Service
    name: vault
    weight: 100
  port:
    targetPort: 8200
  tls:
    termination: edge
    insecureEdgeTerminationPolicy: Redirect
